{
  "name": "job-application-automator",
  "version": "2.0.0",
  "description": "Automated job search and application tool. Searches company career pages directly AND public platforms (LinkedIn, Indeed, Glassdoor). Applies via Greenhouse, Lever, and Workday ATS with human-in-the-loop review.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:companies": "node src/index.js --companies-only",
    "start:platforms": "node src/index.js --platforms-only",
    "test": "playwright test",
    "test:company": "playwright test tests/functional/company.test.js",
    "test:search": "playwright test tests/functional/search.test.js",
    "test:apply": "playwright test tests/functional/apply.test.js",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report test-results/html-report",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.43.0",
    "playwright": "^1.43.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
